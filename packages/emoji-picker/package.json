{
  "name": "frimousse",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exhaled/frimousse.git"
  },
  "main": "./dist/index.cjs",
  "peerDependencies": {
    "react": "^18 || ^19",
    "typescript": ">=5.1.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bugs": {
    "url": "https://github.com/exhaled/frimousse/issues"
  },
  "description": "A lightweight, unstyled, and composable emoji picker for React.",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/exhaled/frimousse",
  "keywords": [
    "emoji",
    "emoji picker",
    "react",
    "unstyled",
    "component",
    "emojibase",
    "liveblocks"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.1",
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown --minify",
    "test": "vitest run --silent",
    "test:watch": "vitest watch --silent",
    "test:coverage": "bun run test -- --coverage",
    "format": "biome check --write",
    "lint": "bun run lint:tsc && bun run lint:biome && bun run lint:package",
    "lint:tsc": "tsc --noEmit",
    "lint:biome": "biome lint",
    "lint:package": "publint --strict && attw --pack",
    "release": "release-it --config ../../.release-it.json"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.mts"
}
